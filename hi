void followLine(int type, int port, int direction){
    if (type == 0){
        while (digital(0) == 0){
            if (analog(port) < white){
                motor(left, 90*direction);
                motor(right, 5*direction);
            }
            else if (analog(port) > white){
                motor(left, 5*direction);
                motor(right, 90*direction);
            }
        }
    }
}

